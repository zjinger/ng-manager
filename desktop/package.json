{
  "name": "desktop",
  "version": "1.0.0",
  "description": "Ng-Manager Electron desktop shell",
  "main": "app/main/main.js",
  "type": "module",
  "keywords": [],
  "author": "",
  "build": {
    "appId": "com.yinuo.ngmanager.desktop",
    "productName": "Ng-Manager",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "runtime/**/*"
    ],
    "files": [
      "app/**/*",
      "runtime/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icons/favicon.ico",
      "target":{
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    }
  },
  "scripts": {
    "electron": "electron",
    "electron:serve-tsc": "tsc -p tsconfig.dev.json -w",
    "electron:build-tsc": "tsc -b tsconfig.build.json --force",
    "electron:prepare-runtime": "node ./scripts/prepare-runtime.cjs",
    "electron:serve-main": "electronmon . --serve",
    "electron:serve": "concurrently -n TSC,ELECTRON -c cyan,magenta \"npm run electron:serve-tsc\" \"wait-on tcp:4200 && npm run electron:serve-main\"",
    "electron:local": "electron .",
    "electron:build": "rimraf app runtime && npm run electron:build-tsc && npm run electron:prepare-runtime && node ./scripts/electron-builder-wrapper.cjs build --publish=never"
  },
  "dependencies": {},
  "devDependencies": {
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@yinuo-ngm/api": "file:../packages/api",
    "@yinuo-ngm/core": "file:../packages/core",
    "@yinuo-ngm/server": "file:../packages/server",
    "@yinuo-ngm/sprite": "file:../packages/sprite",
    "@yinuo-ngm/storage": "file:../packages/storage",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "js-yaml": "^4.1.1",
    "jsonc-parser": "^3.3.1",
    "launch-editor": "^2.12.0",
    "mime-types": "^2.1.35",
    "node-pty": "^1.1.0",
    "@types/node": "^25.0.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "26.8.1",
    "electron-debug": "^4.1.0",
    "electron-reloader": "^1.2.3",
    "electronmon": "^2.0.4",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.2",
    "rss-parser": "^3.13.0",
    "spritesmith": "^3.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "undici": "^7.20.0",
    "wait-on": "^9.0.3"
  }
}
