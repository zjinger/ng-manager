{
  "name": "desktop",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main/main.js",
  "keywords": [],
  "author": "",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "electron": "electron",
    "electron:serve-tsc": "tsc -p tsconfig.dev.json -w",
    "electron:build-tsc": "tsc -p tsconfig.build.json",
    "electron:serve-main": "electronmon . --serve",
    "electron:serve": "concurrently -n TSC,ELECTRON -c cyan,magenta \"npm run electron:serve-tsc\" \"wait-on tcp:4200 && npm run electron:serve-main\"",
    "electron:local": "electron .",
    "electron:build": "rimraf dist && npm run electron:build-tsc && electron-builder build --publish=never"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-debug": "^4.1.0",
    "electron-reloader": "^1.2.3",
    "electronmon": "^2.0.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3"
  }
}
