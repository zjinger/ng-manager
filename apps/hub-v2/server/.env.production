# =========================
# Server
# =========================

NODE_ENV=production
HOST=0.0.0.0
PORT=7008

# =========================
# Data & Storage
# =========================

# 数据目录（数据库、上传文件等）
DATA_DIR=/opt/ngm-hub-v2/data

# =========================
# Logging
# =========================

# trace | debug | info | warn | error
LOG_LEVEL=error

# 日志目录（pm2 输出日志）
LOG_DIR=/opt/ngm-hub-v2/current/logs

# =========================
# Auth
# =========================

JWT_SECRET=aS5lux0rqgK0BshGwzi8tQkHAPQenFsAaseRcL1CDuW4eMFNvB9RPa5YmcxCO8ueVGA2MAKyqfeQOJJLFTg
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_NAME=ngm_hub_v2_token
AUTH_TOKEN_EXPIRES_IN=7d
# HTTPS（先保留配置，当前默认关闭，回到 HTTP 上线）
HTTPS_ENABLED=false
HTTPS_KEY_FILE=/opt/ngm-hub-v2/shared/ssl/tls.key
HTTPS_CERT_FILE=/opt/ngm-hub-v2/shared/ssl/tls.crt
LOGIN_RSA_PRIVATE_
LOGIN_RSA_PUBLIC_

# =========================
# Default Admin Seed
# =========================

# 首次启动创建管理员
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=Ad@_2o26!
INIT_ADMIN_NICKNAME=Administrator

# =========================
# Upload
# =========================

# 单文件最大大小 (bytes)
UPLOAD_MAX_FILE_SIZE=10485760 # 10 MB

# 最大文件数量
UPLOAD_MAX_FILES=10

# 上传目录
UPLOAD_DIR=/opt/ngm-hub-v2/data/uploads

# =========================
# OpenAI API
# =========================
# deepseek.com 端点和 API Key，替换为你的实际值
OPENAI_API_KEY=sk-c7f6c7c93686457e8d90d8e7f06362e7
# 使用 DeepSeek 端点
OPENAI_BASE_URL=https://api.deepseek.com/v1  
# 使用 DeepSeek 模型
OPENAI_MODEL=deepseek-chat


# =========================
# Other Configurations
# =========================
REPORT_PUBLIC_ENABLED=true



