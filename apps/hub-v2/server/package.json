{
  "name": "ngm-hub-v2-server",
  "version": "2.1.4",
  "private": true,
  "description": "ng-manager hub v2 server",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "test": "tsx --test src/modules/ai/ai-report-sql.service.test.ts",
    "uploads:migrate-paths": "tsx src/scripts/migrate-upload-paths.ts",
    "uploads:migrate-paths:dist": "node dist/scripts/migrate-upload-paths.js",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "db:seed": "tsx src/db/seed-cli.ts",
    "db:migrate:from-v1": "tsx src/db/migrate-from-v1.ts",
    "db:verify:from-v1": "tsx src/db/migrate-from-v1.verify.ts",
    "project:normalize-display-code": "tsx src/scripts/normalize-project-display-code.ts",
    "project:normalize-display-code:dist": "node dist/scripts/normalize-project-display-code.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/websocket": "^11.2.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.0",
    "fastify-plugin": "^5.0.1",
    "nanoid": "^5.1.5",
    "openai": "^4.104.0",
    "pinyin-pro": "^3.27.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "rimraf": "^6.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0"
  }
}
