{
  "name": "ng-manager",
  "private": true,
  "scripts": {
    "clean": "rimraf -g \"packages/**/lib\" \"packages/**/dist\" \"packages/**/*.tsbuildinfo\"",
    "clean:githead": "node scripts/clean-githead.mjs",
    "check:githead": "node scripts/clean-githead.mjs --check",
    "clean:pack": "rimraf .artifacts/npm",

    "build": "tsc -b tsconfig.build.json",
    "build:clean": "npm run clean && npm run build",
    "build:since": "lerna run build --since --stream",
    "since": "lerna ls --since --json",

    "dev": "lerna run dev --stream --parallel",
    "dev:server": "tsx watch packages/server/src/index.ts",

    "clean:server-www": "rimraf packages/server/www",
    "prepare:server-www": "npm run clean:server-www && cd webapp && npm run web:build",
    "release:preflight": "npm run check:githead && npm run clean && npm run build && npm run prepare:server-www && npm run pack:all",
    "release:dry": "npm run release:preflight",
    "release:changed": "lerna changed",
    "release:version": "lerna version",
    "release:publish:git": "lerna publish from-git",
    "release:publish:pkg": "lerna publish from-package",

    "pack:all": "node scripts/pack-all.mjs",
    "pack:sketch-plugin": "npm run pack:sketch -w @yinuo-ngm/design-handoff",
    "pack:list": "node scripts/pack-all.mjs --list",
    "handoff:scan": "npm run handoff:scan -w @yinuo-ngm/design-handoff --",
    "handoff:task": "npm run handoff:task -w @yinuo-ngm/design-handoff --",
    "publish:all": "npm run release:publish:pkg",

    "build:core": "tsc -b packages/core",
    "build:server": "tsc -b packages/server && cd webapp && npm run web:build",
    "build:ais": "tsc -b packages/ais",
    "build:sprite": "tsc -b packages/sprite",

    "test:cli:ui": "node packages/cli/lib/bin/ngm.js ui"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "lerna": "^9.0.3",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  }
}
