{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "independent",
  "npmClient": "npm",
  "packages": ["packages/*"],
  "command": {
    "run": { "stream": true },
    "version": {
      "push": false,
      "ignoreChanges": [
        "**/*.md",
        "**/README.md",
        "**/CHANGELOG.md",
        "**/LICENSE",
        "**/lib/**",
        "**/dist/**",
        "**/*.tsbuildinfo",
        ".artifacts/**",
        "docs/**"
      ]
    }
  }
}
