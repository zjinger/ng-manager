{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "baseUrl": ".",
    "paths": {
      "@core": ["core/src/index.ts"],
      "@core/*": ["core/src/*"],
      "@api": ["api/src/index.ts"],
      "@api/*": ["api/src/*"]
    }
  },
  "references": [
    { "path": "../core" },
    { "path": "../sprite" },
    { "path": "../api" }
  ]
}
