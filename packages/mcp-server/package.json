{
  "name": "@yinuo-ngm/mcp-server",
  "version": "0.1.0",
  "description": "Local MCP stdio server for ng-manager core capabilities.",
  "author": "ZhangJing <892295834@qq.com>",
  "license": "ISC",
  "bin": {
    "ngm-mcp-server": "lib/index.js"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "files": [
