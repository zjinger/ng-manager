{
  "name": "@yinuo-ngm/design-handoff",
  "version": "0.1.1",
  "description": "AI-friendly design handoff parser and Sketch plugin for ng-manager",
  "author": "ZhangJing <892295834@qq.com>",
  "license": "ISC",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "sketchplugin"
  ],
  "publishConfig": {
