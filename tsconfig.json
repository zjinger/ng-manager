{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "target": "es2020",
    "module": "commonjs",
    "declaration": true,
    "sourceMap": false,
    "composite": true,
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "removeComments": true,
    "forceConsistentCasingInFileNames": true,
    "declarationMap": false
  },
  "include": ["src/**/*.ts","src/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "webapp",
    "apps",
    "**/.angular",
    "**/dist",
    "**/out-tsc"
  ]
}
